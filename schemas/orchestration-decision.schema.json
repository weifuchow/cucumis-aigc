{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Orchestration Decision",
  "type": "object",
  "additionalProperties": false,
  "required": ["timestamp", "decision_type", "reason", "payload"],
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "decision_type": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "payload": {
      "type": "object"
    }
  }
}
