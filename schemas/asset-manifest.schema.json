{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Asset Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["assets"],
  "properties": {
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["asset_id", "kind", "path"],
        "properties": {
          "asset_id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": ["image", "video", "audio", "subtitle", "other"]
          },
          "path": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
