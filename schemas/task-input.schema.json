{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Task Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "topic",
    "goal",
    "duration_seconds",
    "language",
    "aspect_ratio",
    "style",
    "music_emotion",
    "pacing_preference",
    "audio_model",
    "image_model",
    "video_model",
    "requires_voiceover",
    "requires_subtitles"
  ],
  "properties": {
    "topic": {
      "type": "string",
      "minLength": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "duration_seconds": {
      "type": "integer",
      "minimum": 1
    },
    "language": {
      "type": "string",
      "minLength": 1
    },
    "aspect_ratio": {
      "type": "string",
      "enum": [
        "16:9",
        "9:16",
        "1:1",
        "4:3"
      ]
    },
    "style": {
      "type": "string",
      "minLength": 1
    },
    "music_emotion": {
      "type": "string",
      "minLength": 1
    },
    "pacing_preference": {
      "type": "string",
      "minLength": 1
    },
    "audio_model": {
      "type": "string",
      "minLength": 1
    },
    "video_model": {
      "type": "string",
      "minLength": 1
    },
    "requires_voiceover": {
      "type": "boolean"
    },
    "requires_subtitles": {
      "type": "boolean"
    },
    "image_model": {
      "type": "string",
      "minLength": 1
    }
  }
}
