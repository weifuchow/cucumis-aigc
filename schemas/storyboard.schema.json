{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Storyboard",
  "type": "object",
  "additionalProperties": false,
  "required": ["scenes"],
  "properties": {
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "scene_id",
          "purpose",
          "visual_description",
          "estimated_duration_seconds",
          "asset_mode",
          "subtitle_text"
        ],
        "properties": {
          "scene_id": {
            "type": "string",
            "minLength": 1
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          },
          "visual_description": {
            "type": "string",
            "minLength": 1
          },
          "estimated_duration_seconds": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "asset_mode": {
            "type": "string",
            "enum": ["static", "dynamic", "mixed"]
          },
          "subtitle_text": {
            "type": "string"
          }
        }
      }
    }
  }
}
