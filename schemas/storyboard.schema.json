{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Storyboard",
  "type": "object",
  "additionalProperties": false,
  "required": ["scenes"],
  "properties": {
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "scene_id",
          "purpose",
          "visual_description",
          "start_time",
          "end_time",
          "duration_seconds",
          "asset_mode",
          "subtitle_text",
          "beat_alignment",
          "transition_intent",
          "motion_intent"
        ],
        "properties": {
          "scene_id": {
            "type": "string",
            "minLength": 1
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          },
          "visual_description": {
            "type": "string",
            "minLength": 1
          },
          "start_time": {
            "type": "number",
            "minimum": 0
          },
          "end_time": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "duration_seconds": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "asset_mode": {
            "type": "string",
            "enum": ["static", "dynamic", "mixed"]
          },
          "subtitle_text": {
            "type": "string"
          },
          "beat_alignment": {
            "type": "string",
            "minLength": 1
          },
          "transition_intent": {
            "type": "string",
            "minLength": 1
          },
          "motion_intent": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
