{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Render Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "timeline_source",
    "duration_seconds",
    "inputs",
    "checks",
    "stages",
    "shot_plan",
    "ffmpeg",
    "output"
  ],
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "timeline_source": {
      "type": "string",
      "minLength": 1
    },
    "duration_seconds": {
      "type": "number",
      "minimum": 0
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "required"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "boolean"
          }
        }
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["check_id", "status", "detail"],
        "properties": {
          "check_id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["pass", "fail"]
          },
          "detail": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "stages": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["stage_id", "description"],
        "properties": {
          "stage_id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "shot_plan": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["segment_id", "scene_id", "start", "end", "video_clip_url"],
        "properties": {
          "segment_id": {
            "type": "string",
            "minLength": 1
          },
          "scene_id": {
            "type": "string",
            "minLength": 1
          },
          "start": {
            "type": "number",
            "minimum": 0
          },
          "end": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "video_clip_url": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "ffmpeg": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "binary", "args_template", "notes"],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "binary": {
          "type": "string",
          "minLength": 1
        },
        "args_template": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "container"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "container": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
