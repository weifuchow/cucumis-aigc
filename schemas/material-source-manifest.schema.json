{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Material Source Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "generated_at",
    "source_root",
    "scan",
    "assets"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "source_root": {
      "type": "string",
      "minLength": 1
    },
    "scan": {
      "type": "object"
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  }
}
