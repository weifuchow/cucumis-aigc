{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Material Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "generated_at",
    "workflow",
    "assets"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "workflow": {
      "type": "string",
      "minLength": 1
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "summary": {
      "type": "object"
    }
  }
}
