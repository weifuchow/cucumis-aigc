{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Material Editorial Subtasks",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "workflow",
    "updated_at",
    "tasks"
  ],
  "properties": {
    "workflow": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "minLength": 1
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  }
}
