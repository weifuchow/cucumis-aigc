{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Orchestration State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "current_stage",
    "completed_stages",
    "skipped_stages",
    "last_failed_stage",
    "next_stage"
  ],
  "properties": {
    "current_stage": {
      "type": ["string", "null"]
    },
    "completed_stages": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "skipped_stages": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "last_failed_stage": {
      "type": ["string", "null"]
    },
    "next_stage": {
      "type": ["string", "null"]
    },
    "workflow": {
      "type": ["string", "null"]
    },
    "phase": {
      "type": ["string", "null"]
    },
    "checkpoint_status": {
      "type": ["string", "null"]
    },
    "active_batch_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "resume_from": {
      "type": ["string", "null"]
    },
    "last_handoff_path": {
      "type": ["string", "null"]
    }
  }
}
